{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@editor/*": ["../src/*"]
    }
  },
  "include": ["src", "../src/features/ilmiot/data.ts", "../src/data/recipes.ts"]
}
